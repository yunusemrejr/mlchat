# ============================================================
# ML Chat — Git Ignore Rules
# Everything in dev/ stays local. Only root files go to GitHub.
# ============================================================

# Developer workspace (local notes, caches, experiments, drafts)
dev/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Downloaded libraries (loaded from CDN at runtime)
transformers.min.js
transformers.js
*.min.js.map

# ONNX Runtime WASM binaries (downloaded by browser on first run)
ort-wasm*.wasm

# Model caches that may appear locally
models/
cached_models/
.onnx/

# Logs
*.log
npm-debug.log*

# Environment / secrets (never commit these)
.env
.env.local
.env.*.local
secrets/
*.pem
*.key

# Node modules (if ever added)
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
